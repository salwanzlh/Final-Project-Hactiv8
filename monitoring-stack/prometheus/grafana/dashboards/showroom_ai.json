{
  "title": "Showroom AI — Overview",
  "uid": "showroom-ai-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "tags": [
    "showroom",
    "ai"
  ],
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Live Status",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Sesi Aktif",
      "description": "WebSocket sessions yang sedang berlangsung sekarang",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "mappings": []
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "showroom_ai_sesi_aktif",
          "legendFormat": "Sesi Aktif",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Rekomendasi (1h)",
      "description": "Jumlah mobil yang direkomendasikan dalam 1 jam terakhir",
      "gridPos": {
        "x": 4,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "increase(showroom_ai_rekomendasi_total[1h])",
          "legendFormat": "Rekomendasi",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "LLM Error Rate",
      "description": "% request LLM yang gagal dalam 5 menit terakhir",
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.05
              },
              {
                "color": "red",
                "value": 0.2
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(showroom_ai_llm_requests_total{status=\"gagal\"}[5m]) / rate(showroom_ai_llm_requests_total[5m])",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "LLM P95 Latency",
      "description": "Persentil ke-95 durasi LLM response",
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1.5
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, rate(showroom_ai_llm_latency_seconds_bucket[5m]))",
          "legendFormat": "P95",
          "refId": "A"
        }
      ]
    },
